{
  "name": "patrimonia",
  "version": "1.0.0",
  "description": "PatrimonIA — Gestor de Patrimônio Familiar",
  "main": "main.js",
  "author": "PatrimonIA",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build:installer": "electron-builder --win --x64",
    "publish:release": "electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.patrimonia.app",
    "productName": "PatrimonIA",
    "copyright": "Copyright © 2026 PatrimonIA",
    "directories": {
      "output": "../dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "first-run.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/patrimonia-backend.exe",
        "to": "backend/patrimonia-backend.exe"
      },
      {
        "from": "../backend/server.env",
        "to": "server.env"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../version.json",
        "to": "version.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PatrimonIA",
      "installerHeaderIcon": "assets/icon.ico",
      "displayLanguageSelector": false,
      "artifactName": "PatrimonIA-Setup-${version}.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "fortemoveis-cloud",
      "repo": "patrimonia",
      "private": false
    }
  }
}
